NODE_ENV=production
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
DB_SEARCH_PATH=public
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_APP_URL=https://your-production-domain.com

# Optional when running the frontend and API on the same Vercel project.
# Add extra comma-separated origins here for custom domains or other frontends.
ALLOWED_ORIGINS=https://your-production-domain.com,https://your-preview-domain.vercel.app

# Transactional email for password reset
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=RecruitFlow <no-reply@your-domain.com>

# AI provider
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free,nvidia/nemotron-3-super-120b-a12b:free,liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_SITE_URL=https://your-production-domain.com
OPENROUTER_APP_NAME=RecruitFlaw ATS
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional alternate AI providers / legacy fallbacks
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CV_PARSE_MODEL=
CV_PARSE_MODEL=
REPLIT_AI_TOKEN=

# Production file storage on Vercel
STORAGE_BACKEND=vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional size guards for Vercel server uploads
MAX_UPLOAD_BYTES=4000000
MAX_CV_PARSE_PDF_BYTES=4000000

# Local development fallbacks
LOCAL_DEV=0
LOCAL_STORAGE_DIR=.local-storage
API_PROXY_TARGET=http://localhost:8080
PORT=5173
BASE_PATH=/

# Legacy Replit object storage mode
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=
