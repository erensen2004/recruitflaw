{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/ats-platform/dist/public",
  "functions": {
    "api/[...route].ts": {
      "includeFiles": "node_modules/.pnpm/{pdfjs-dist@*,node_modules/@napi-rs,@napi-rs+canvas*@*}/**/*"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...route]"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
