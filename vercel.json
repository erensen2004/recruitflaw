{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:vercel && pnpm run vercel:prepare-static",
  "outputDirectory": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[[...route]].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
